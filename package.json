{
  "name": "kenren-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@8.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:site": "pnpm --filter @kenren/site dev",
    "build:site": "pnpm --filter @kenren/site build",
    "deploy:site": "pnpm build:site && firebase deploy --only hosting:kenren"
  }
}
