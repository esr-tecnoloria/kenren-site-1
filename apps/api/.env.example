# Postgres (Cloud SQL via Auth Proxy on localhost during dev)
DATABASE_URL="postgresql://postgres:CHANGE_ME@127.0.0.1:5432/kenren_main?schema=kenren"

# Firebase Admin (service account JSON path or inline JSON)
# In Cloud Run: leave GOOGLE_APPLICATION_CREDENTIALS unset and rely on default service account.
# Locally: download a service account key and point to it.
FIREBASE_PROJECT_ID="guia-do-festival-do-japao"
GOOGLE_APPLICATION_CREDENTIALS=""

# GCS
GCS_BUCKET="kenren-media"

# Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# CORS (comma-separated)
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,https://kenren.web.app,https://kenren-admin.web.app"
